# Backend Production Environment Variables
# Copy to .env in production environment (e.g., Railway dashboard)

# Provider mode: "mock" (testing) or "real" (production)
PROVIDER_MODE=real

# Logging level
LOG_LEVEL=info

# OpenAI API Key (REQUIRED for production)
# Get from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Optional: Override provider URLs (if using different providers)
# ASR_PROVIDER_URL=https://api.openai.com/v1/audio/transcriptions
# LLM_PROVIDER_URL=https://api.openai.com/v1/chat/completions
# TTS_PROVIDER_URL=https://api.openai.com/v1/audio/speech

# Optional: CORS configuration
# CORS_ORIGINS=https://real-time-voice-assistant.vercel.app

# Web Search (Tavily API) — enables real-time web search for current info
# Get your free API key at: https://tavily.com (1000 searches/month free)
# SEARCH_API_KEY=tvly-your-key-here
# ENABLE_WEB_SEARCH=true
