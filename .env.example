# Real-Time Voice Assistant Configuration
# Copy this file to .env and fill in your actual values

# Provider Mode: "mock" (for testing) or "real" (for production)
# - mock: Uses mock services on localhost:9000 (no API keys needed)
# - real: Uses provider URLs and API keys below
PROVIDER_MODE=mock

# ASR (Speech-to-Text) Provider (used when PROVIDER_MODE=real)
ASR_PROVIDER_URL=http://localhost:9001/asr/stream
ASR_API_KEY=your_asr_api_key_here

# LLM (Language Model) Provider (used when PROVIDER_MODE=real)
LLM_PROVIDER_URL=http://localhost:9002/llm/stream
LLM_API_KEY=your_llm_api_key_here

# TTS (Text-to-Speech) Provider (used when PROVIDER_MODE=real)
TTS_PROVIDER_URL=http://localhost:9003/tts/stream
TTS_API_KEY=your_tts_api_key_here

# Web Search (Tavily API) — enables real-time web search for current info
# Get your free API key at: https://tavily.com (1000 searches/month free)
SEARCH_API_KEY=your_tavily_api_key_here
ENABLE_WEB_SEARCH=true

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_REQUIRE_TLS=false

# Optional: TLS Certificate Paths (for production WSS)
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem
