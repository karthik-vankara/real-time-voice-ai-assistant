# Real-Time Voice Assistant Configuration
# Copy this file to .env and fill in your actual values

# ASR (Speech-to-Text) Provider
ASR_PROVIDER_URL=http://localhost:9001/asr/stream
ASR_API_KEY=your_asr_api_key_here

# LLM (Language Model) Provider
LLM_PROVIDER_URL=http://localhost:9002/llm/stream
LLM_API_KEY=your_llm_api_key_here

# TTS (Text-to-Speech) Provider
TTS_PROVIDER_URL=http://localhost:9003/tts/stream
TTS_API_KEY=your_tts_api_key_here

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_REQUIRE_TLS=false

# Optional: TLS Certificate Paths (for production WSS)
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem
