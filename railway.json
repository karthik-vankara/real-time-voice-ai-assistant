{
  "$schema": "https://railway.app/json-schema/railway.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn src.server:create_app --host 0.0.0.0 --port 8000 --factory",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  },
  "variables": {
    "PROVIDER_MODE": "real",
    "LOG_LEVEL": "info"
  }
}
